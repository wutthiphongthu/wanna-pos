rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userData() {
      return get(userDocPath()).data;
    }

    /// ผูกกับร้านนี้แล้ว (หลังสร้างร้าน / อัปเดต user doc แล้ว)
    function isMemberOfStore(storeId) {
      return isAuthenticated() &&
        exists(userDocPath()) &&
        userData().keys().hasAll(['storeId']) &&
        userData().storeId == storeId;
    }

    /// สร้างร้านแรกได้เมื่อล็อกอินแล้วและยังไม่มีร้านผูก (ไม่มีฟิลด์ storeId หรือ storeId ว่าง)
    function canCreateFirstStore() {
      return isAuthenticated() &&
        exists(userDocPath()) &&
        (
          !userData().keys().hasAll(['storeId']) ||
          userData().storeId == ''
        );
    }

    // users/{uid} — เฉพาะ user ตัวเอง
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /stores/{storeId} {
      // สร้างเอกสารร้านใหม่ (หน้า CreateStore) — ต้องยังไม่มี storeId ใน user doc
      allow create: if canCreateFirstStore();

      allow read, update, delete: if isMemberOfStore(storeId);

      match /products/{productId} {
        allow read, write: if isMemberOfStore(storeId);
      }
      match /members/{memberId} {
        allow read, write: if isMemberOfStore(storeId);
      }
      match /categories/{categoryId} {
        allow read, write: if isMemberOfStore(storeId);
      }
      match /sales/{saleId} {
        allow read, write: if isMemberOfStore(storeId);
        match /line_items/{lineItemId} {
          allow read, write: if isMemberOfStore(storeId);
        }
      }
      match /settings/{settingId} {
        allow read, write: if isMemberOfStore(storeId);
      }
    }
  }
}
