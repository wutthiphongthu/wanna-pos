rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ผู้ใช้ login แล้วเข้าถึงได้ทุก docs (เหมาะสำหรับพัฒนา — production ควรใช้ isStoreMember)
    function isAuthenticated() {
      return request.auth != null;
    }

    // users/{uid} — เฉพาะ user ตัวเอง
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // stores และ subcollections ทั้งหมด — user ที่ login แล้วเข้าถึงได้
    match /stores/{storeId} {
      allow read, write: if isAuthenticated();
      match /products/{productId} {
        allow read, write: if isAuthenticated();
      }
      match /members/{memberId} {
        allow read, write: if isAuthenticated();
      }
      match /categories/{categoryId} {
        allow read, write: if isAuthenticated();
      }
      match /sales/{saleId} {
        allow read, write: if isAuthenticated();
        match /line_items/{lineItemId} {
          allow read, write: if isAuthenticated();
        }
      }
      match /settings/{settingId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
